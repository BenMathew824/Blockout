{
  "manifest_version": 3,
  "name": "Locked In",
  "version": "1.0",
  "description": "AI-powered study focus tool",
  "permissions": ["tabs", "storage", "alarms", "webNavigation"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}