{
  "manifest_version": 3,
  "name": "Locked In",
  "version": "1.0",
  "description": "AI-powered study focus tool",
  "permissions": ["tabs", "storage", "alarms", "webNavigation"],
  "host_permissions": ["https://api.anthropic.com/*", "https://*.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["focusBorder.js"],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "matches": ["https://YOUR-DEPLOYED-DOMAIN.vercel.app/*", "http://localhost:*/*"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}